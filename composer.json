{
    "name": "just-bases/php-qa-base",
    "description": "PHP QA Metapackage",
    "type": "metapackage",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "dantleech/what-changed": "^0.4.5",
        "deptrac/deptrac": "^4.6",
        "friendsofphp/php-cs-fixer": "^3.95",
        "pdepend/pdepend": "^2.2",
        "phpat/phpat": "^0.12.4",
        "phpbench/phpbench": "^1.7",
        "phpmd/phpmd": "^2.5",
        "phpmetrics/phpmetrics": "^2.9",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-strict-rules": "^2.0",
        "povils/phpmnd": "^3.6",
        "rector/rector": "^2.5",
        "rskuipers/php-assumptions": "^0.9.1",
        "scheb/tombstone-logger": "^1.10",
        "seld/jsonlint": "^1.12",
        "shipmonk/dead-code-detector": "^1.2",
        "shipmonk/name-collision-detector": "^2.1",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dantleech/what-changed": true,
            "phpstan/extension-installer": true
        }
    }
}
